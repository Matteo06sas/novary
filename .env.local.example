# Access key for the "Richiedi consulenza" form (components/consulenza-form.tsx).
# Submitted directly from the browser to Web3Forms (their Cloudflare protection
# blocks server-to-server requests), so this must be NEXT_PUBLIC_ to be readable
# client-side. That's expected: Web3Forms access keys only authorize submissions,
# they're not a traditional secret.
# Get one free, no signup, at https://web3forms.com — enter novary.dev@gmail.com,
# you'll receive the key by email in ~30 seconds.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
